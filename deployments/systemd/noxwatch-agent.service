[Unit]
Description=NoxWatch Linux monitoring agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/noxwatch-agent -config /etc/noxwatch/agent.yaml run
Restart=on-failure
RestartSec=10s
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/etc/noxwatch
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
